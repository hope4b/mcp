      {"from": "search_relation_templates", "requires": ["realm_id"], "produces": ["relation_type_name", "template_id"]},
      {"from": "search_agent_memory", "requires": ["realm_id", "entity_id"], "produces": ["record_id"]},
      {"from": "search_memory_artifacts", "requires": ["realm_id"], "produces": ["artifact_id"]},
