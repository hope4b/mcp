  "safety_modes": {
    "read_only": {
      "aliases": ["readonly", "read-only", "conservative", "safe"],
      "allows": ["read_only"],
      "description": "Inspection and discovery only. Write, destructive, lifecycle, admin-like, and high-risk actions are blocked."
    },
    "write_intent": {
      "aliases": ["write", "write-intent", "mutation"],
      "allows": ["read_only", "write", "high_risk"],
      "description": "Read, ordinary write, and owner-approved high-risk write guidance. Required IDs must be present or obtained before mutation."
    },
    "destructive_intent": {
      "aliases": ["destructive", "delete", "delete_intent"],
      "allows": ["read_only", "write", "destructive"],
      "description": "Destructive guidance stays separately gated and requires explicit operator intent, ownership, authorization, and exact IDs."
    },
    "lifecycle_intent": {
      "aliases": ["lifecycle", "status", "transition", "approval"],
      "allows": ["read_only", "write", "high_risk", "lifecycle"],
      "description": "Owner-approved high-risk write plus lifecycle/status-transition guidance stays separately gated and requires explicit operator intent, ownership, authorization, and exact IDs."
    }
  },
  "safety_taxonomy": {
    "read_only": "Does not intentionally mutate Onto state.",
    "write": "Creates or updates ordinary Onto state without deletion or lifecycle transition.",
    "destructive": "Deletes or removes existing Onto state and must be gated separately from ordinary writes.",
    "lifecycle": "Changes review/status/lifecycle state and must be gated separately from ordinary writes.",
    "admin_like": "Changes workspace-level or cross-session state and requires operator awareness.",
    "high_risk": "Can overwrite, supersede, or broadly alter agent-visible state; requires extra review even when not a delete."
  },
  "general_start": {
    "recommended_first_reads": [
      "Call how_to_use_onto_mcp with question set to the user goal plus known inputs, and the most conservative safety_mode that fits.",
      "Call list_available_realms to obtain a realm_id before realm-scoped tools.",
      "Use read-only search/get tools to collect template_id, entity_id, diagram_id, tag_id, relation type name, node_id, or artifact_id before mutations.",
      "Use about_onto only for semantic Onto orientation, not operational sequencing."
    ],
    "next_constraints": [
      "Do not call write, destructive, or lifecycle tools until required IDs and operator intent are explicit.",
      "Unknown or ambiguous tasks must stay on read-only discovery until clarified.",
      "Destructive and lifecycle actions are never ordinary writes."
    ]
  },
  "id_dependency_graph": {
    "ids": {
      "realm_id": "Workspace identifier. Usually obtained from list_available_realms.",
      "template_id": "Template/meta entity identifier. Obtained from search_templates, get_template, save_template, or create_template.",
